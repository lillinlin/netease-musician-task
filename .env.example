# 复制本文件为 .env 后按需修改。
# 优先级：真实环境变量（Docker environment / export）> .env 文件 > 代码默认值。
# 注意：这些只是「初始默认值」，应用首次建库时播种进 settings 表；
#       之后请在 Web「全局设置」里修改（保存即生效），无需改这里再重启。

# ---- Web 服务 ----
# 监听地址与端口
APP_HOST=0.0.0.0
APP_PORT=8000

# ---- 浏览器 ----
# 无头模式：1 无头（服务器部署），0 弹真实窗口（本地调试）
PLAYWRIGHT_HEADLESS=1
# 异常/风控时是否截图存档到 数据目录/debug/{手机号}/（1 开启，0 关闭）
PLAYWRIGHT_DEBUG_SCREENSHOT=1

# ---- 调度默认值（可被账号级设置覆盖）----
# 每日任务默认执行时间（HH:MM）
SEND_TIME=09:30
# 发布动态的间隔天数
EXECUTION_INTERVAL_DAYS=3
# 每月最大发布次数
MAX_MONTHLY_SENDS=4

# ---- 通知（可选）----
# 企业微信自定义机器人 Webhook 的 key（不填则不发送）
WECOM_WEBHOOK_KEY=
# 自定义 Webhook 完整地址（填写后优先于企业微信）
CUSTOM_WEBHOOK_URL=
# 自定义 Webhook 请求方法，默认 POST
CUSTOM_WEBHOOK_METHOD=POST
# 自定义请求头，JSON 对象或用英文分号分隔的 "Header: value" 列表
CUSTOM_WEBHOOK_HEADERS=
# 自定义请求 Body 模板，支持 ${title} 和 ${content} 占位符
CUSTOM_WEBHOOK_BODY=

# ---- 数据目录（可选）----
# SQLite / 浏览器 profile / 日志 / 调试截图 都放这里
# APP_DATA_DIR=app/data
